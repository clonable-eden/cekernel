# headless.env — Terminal-free execution for CI/cron/SSH
#
# Uses headless backend with higher concurrency and shorter timeout.
# Note: default.env also uses headless backend with the same settings.
# This profile exists as an explicit name for CEKERNEL_ENV=headless usage.

CEKERNEL_BACKEND=headless
CEKERNEL_MAX_ORCH_CHILDREN=5
CEKERNEL_WORKER_TIMEOUT=1800
