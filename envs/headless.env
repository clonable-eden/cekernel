# headless.env — Terminal-free execution for CI/cron/SSH
#
# Uses headless backend with standard concurrency settings.
# Also serves as the default profile (default.env is a symlink to this file).

CEKERNEL_BACKEND=headless
CEKERNEL_MAX_ORCHESTRATORS=3
CEKERNEL_MAX_ORCH_CHILDREN=5
CEKERNEL_CI_MAX_RETRIES=3
CEKERNEL_WORKER_TIMEOUT=3600
