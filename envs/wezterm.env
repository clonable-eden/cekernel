# wezterm.env — WezTerm backend profile
#
# Uses WezTerm backend with standard concurrency.
# Select via: export CEKERNEL_ENV=wezterm

CEKERNEL_BACKEND=wezterm
CEKERNEL_MAX_ORCHESTRATORS=3
CEKERNEL_MAX_ORCH_CHILDREN=3
CEKERNEL_CI_MAX_RETRIES=3
# Opt-in for interactive backends (a human is watching; see headless.env):
# CEKERNEL_FALLBACK_MODEL=claude-haiku-4-5-20251001
